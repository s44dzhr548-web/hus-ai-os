# Trading AI — Environment Variables
# Copy to .env.local and fill in keys as needed. App builds and runs without any keys (demo fallback).

# US Market Data
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=

# News & Macro
NEWS_API_KEY=
ECONOMIC_CALENDAR_API_KEY=

# Regional / Asset Class
CRYPTO_PROVIDER_KEY=
FOREX_PROVIDER_KEY=
TADAWUL_PROVIDER_KEY=

# AI (optional — rule-based engine works without)
OPENAI_API_KEY=

# Legacy paper broker (optional — execution remains DISABLED)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Note: CoinGecko and Binance public APIs work without keys for crypto.
# Yahoo Finance unofficial fallback works without keys when network allows.
