# Trading AI — Environment Variables
# Real market data mode is ON by default. Paper trading only — NO broker execution.

MARKET_DATA_MODE=live

# --- Market data providers (paste keys after signup; never commit real values) ---
MASSIVE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
FMP_API_KEY=
# Optional MVP skip (~$49/week) — architecture ready; uses FairEconomy calendar fallback
TRADING_ECONOMICS_API_KEY=
NEWS_API_KEY=
COINGECKO_API_KEY=
BINANCE_API_KEY=
TADAWUL_PROVIDER_KEY=

# Legacy / alternate names (still supported)
ALPHA_VANTAGE_API_KEY=
ECONOMIC_CALENDAR_API_KEY=
CRYPTO_PROVIDER_KEY=
FOREX_PROVIDER_KEY=

# AI (optional)
OPENAI_API_KEY=

# Broker keys — DATA ONLY if set; EXECUTION REMAINS DISABLED
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Public without keys: Yahoo Finance, Binance public endpoints, CoinGecko demo, Frankfurter ECB
# Add keys in Vercel → Settings → Environment Variables → redeploy for premium tiers
