# Trading AI — Environment Variables
# Real market data mode is ON by default. Paper trading only — NO broker execution.

# Data mode: live (default) | demo (force mock fallback)
MARKET_DATA_MODE=live

# US Market Data (optional — Yahoo Finance provides live data without keys)
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=

# News & Macro (Yahoo RSS + FairEconomy calendar work without keys)
NEWS_API_KEY=
ECONOMIC_CALENDAR_API_KEY=

# Regional / Asset Class (optional upgrades)
CRYPTO_PROVIDER_KEY=
FOREX_PROVIDER_KEY=
TADAWUL_PROVIDER_KEY=

# AI (optional — rule-based engine works without)
OPENAI_API_KEY=

# Broker keys — DATA ONLY if set; EXECUTION REMAINS DISABLED
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Live without keys: CoinGecko, Binance, Yahoo Finance, Frankfurter ECB, Yahoo News RSS, FairEconomy Calendar
# Add API keys in Vercel → Settings → Environment Variables → redeploy to auto-enable premium providers
