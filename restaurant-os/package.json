{
  "name": "restaurant-os",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-location restaurant operating system — Restaurant OS",
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "prisma generate && next build",
    "start": "next start -p 3005",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "SEED_ENV=production tsx prisma/seed.ts",
    "db:setup:neon": "powershell -ExecutionPolicy Bypass -File scripts/setup-neon.ps1",
    "db:seed:100tables": "tsx scripts/seed-100-tables.ts",
    "db:fix:qr": "tsx scripts/fix-qr-urls.ts",
    "test:smoke": "node scripts/production-smoke-test.mjs",
    "test:audit": "tsx scripts/production-audit.ts",
    "test:phase1": "tsx scripts/phase1-qa-audit.ts",
    "test:r2": "tsx scripts/r2-upload-test.ts",
    "r2:setup-cors": "tsx scripts/r2-setup-cors.ts",
    "test:media-upload": "tsx scripts/production-media-upload-qa.ts",
    "test:permissions": "tsx scripts/permissions-test.ts",
    "test:reception": "tsx scripts/reception-reservations-test.ts",
    "test:tables": "tsx scripts/reception-tables-test.ts",
    "test:reception:edit": "tsx scripts/reception-edit-test.ts",
    "test:reception:full": "tsx scripts/reception-full-test.ts",
    "test:customers": "tsx scripts/customer-history-test.ts",
    "test:staff": "tsx scripts/staff-accounts-test.ts",
    "test:phase1:prod": "node scripts/production-verify.mjs && npm run test:smoke && npm run test:reception && npm run test:customers && npm run test:staff && npm run test:permissions",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && prisma migrate deploy && next build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.9.1",
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
