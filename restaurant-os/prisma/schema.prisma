  receiverTable   DiningTable  @relation("GiftReceiverTable", fields: [receiverTableId], references: [id], onDelete: Cascade)
  product         MenuItem     @relation(fields: [productId], references: [id], onDelete: Restrict)
  order           Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([restaurantId, status])
